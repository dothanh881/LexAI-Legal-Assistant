# =============================================================================
# LexAI - Legal Assistant — Environment Variables Template
# =============================================================================
# Sao chép file này thành .env và điền giá trị thực
# This file IS safe to commit. The actual .env file is gitignored.

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Qdrant (Vector DB) ---
# Local Docker: http://localhost:6333
# Cloud Qdrant: https://your-cluster.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=legal_documents

# --- PostgreSQL (Auth + Session + Log) ---
# Local Docker: postgresql://user:password@localhost:5432/lex_db
# Cloud (Railway/Supabase): postgresql://user:pass@host:port/db
DATABASE_URL=postgresql://user:password@localhost:5432/lex_db

# --- LLM Models ---
SIMPLE_MODEL=gpt-4o-mini
REASONING_MODEL=gpt-4o-mini

# --- BM25 ---
BM25_VOCAB_PATH=src/data/bm25_vocab.json

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Admin UI ---
API_BASE_URL=http://localhost:8000
ADMIN_SECRET=admin123

# --- Chainlit ---
LEX_API_URL=http://localhost:8000/api/v1/chat
CHAIN_TOP_K=5

# --- Web Search (optional) ---
SERPER_API_KEY=
WEB_SEARCH_THRESHOLD=0.1
